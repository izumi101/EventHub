{
  "info": {
    "name": "EventHub API",
    "description": "EventHub API collection for Docker/PostgreSQL local development. Start the stack with docker compose up --build before running requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "organizerAccessToken",
      "value": ""
    },
    {
      "key": "attendeeAccessToken",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": "1"
    },
    {
      "key": "eventId",
      "value": "1"
    },
    {
      "key": "createdEventId",
      "value": "1"
    },
    {
      "key": "registrationId",
      "value": "1"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Random User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user_{{$timestamp}}\",\n  \"email\": \"postman_{{$timestamp}}@eventhub.local\",\n  \"password\": \"password123\",\n  \"password2\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.tokens.access);",
                  "pm.collectionVariables.set(\"refreshToken\", json.tokens.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Organizer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"organizer\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.tokens.access);",
                  "pm.collectionVariables.set(\"refreshToken\", json.tokens.refresh);",
                  "pm.collectionVariables.set(\"organizerAccessToken\", json.tokens.access);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Attendee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"attendee\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.tokens.access);",
                  "pm.collectionVariables.set(\"refreshToken\", json.tokens.refresh);",
                  "pm.collectionVariables.set(\"attendeeAccessToken\", json.tokens.access);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/profile/"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Ali\",\n  \"last_name\": \"Nurkadyr\",\n  \"profile\": {\n    \"bio\": \"Event organizer and API tester\",\n    \"phone\": \"+7 777 123 4567\",\n    \"location\": \"Almaty\"\n  }\n}"
            },
            "url": "{{baseUrl}}/auth/profile/"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/token/refresh/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", json.access);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/logout/"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (Array.isArray(json) && json.length) { pm.collectionVariables.set(\"categoryId\", json[0].id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{organizerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Category {{$timestamp}}\",\n  \"description\": \"Created from Postman\"\n}"
            },
            "url": "{{baseUrl}}/categories/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set(\"categoryId\", json.id); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/?ordering=-date&page=1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const results = json.results || json;",
                  "if (Array.isArray(results) && results.length) {",
                  "  pm.collectionVariables.set(\"eventId\", results[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{organizerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman API Workshop {{$timestamp}}\",\n  \"description\": \"A disposable event created by the Postman collection.\",\n  \"category_id\": {{categoryId}},\n  \"date\": \"2026-05-01T18:00:00Z\",\n  \"end_date\": \"2026-05-01T20:00:00Z\",\n  \"location\": \"Almaty, Kazakhstan\",\n  \"address\": \"Dostyk Plaza, 5th floor\",\n  \"price\": 0,\n  \"max_participants\": 100,\n  \"is_online\": false,\n  \"online_link\": \"\"\n}"
            },
            "url": "{{baseUrl}}/events/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set(\"createdEventId\", json.id);",
                  "  pm.collectionVariables.set(\"eventId\", json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Created Event",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/events/{{createdEventId}}/"
          }
        },
        {
          "name": "Update Created Event",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{organizerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman API Workshop Updated\",\n  \"description\": \"Updated by Postman against the Dockerized backend.\",\n  \"category_id\": {{categoryId}},\n  \"date\": \"2026-05-01T18:00:00Z\",\n  \"end_date\": \"2026-05-01T20:30:00Z\",\n  \"location\": \"Almaty, Kazakhstan\",\n  \"address\": \"Dostyk Plaza, 5th floor\",\n  \"price\": 0,\n  \"max_participants\": 150,\n  \"is_online\": false,\n  \"online_link\": \"\"\n}"
            },
            "url": "{{baseUrl}}/events/{{createdEventId}}/"
          }
        },
        {
          "name": "Event Registrations",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{organizerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/events/{{createdEventId}}/registrations/"
          }
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Register For Created Event",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{attendeeAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Registered from Postman.\"\n}"
            },
            "url": "{{baseUrl}}/events/{{createdEventId}}/register/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set(\"registrationId\", json.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel Created Event Registration",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{attendeeAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/events/{{createdEventId}}/cancel/"
          }
        },
        {
          "name": "My Events",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{organizerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/my-events/"
          }
        },
        {
          "name": "My Registrations",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{attendeeAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/my-registrations/"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{attendeeAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/payments/create-checkout/{{registrationId}}/"
          },
          "description": "Requires a paid registration and a valid Stripe test key."
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{attendeeAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/payments/verify/?session_id=cs_test_123"
          }
        }
      ]
    },
    {
      "name": "Cleanup",
      "item": [
        {
          "name": "Delete Created Event",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{organizerAccessToken}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/events/{{createdEventId}}/"
          }
        }
      ]
    }
  ]
}
